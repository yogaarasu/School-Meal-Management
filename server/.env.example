PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/school-meal-management
# If using mongodb+srv, URL-encode special chars in username/password (e.g. @ => %40)
JWT_SECRET=replace-with-a-secure-secret
# Comma-separated origins supported. No trailing slash. Wildcards supported (e.g. https://*.vercel.app).
CLIENT_ORIGIN=http://localhost:5173
# Link used in organizer welcome email "Sign In to Portal" button
PORTAL_LOGIN_URL=http://localhost:5173/login
ADMIN_EMAIL=admin@schoolmeal.tn.gov
ADMIN_PASSWORD=Admin@123

# SMTP configuration for welcome emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=TN School Meal Management
SMTP_FROM_EMAIL=no-reply@schoolmeal.tn.gov
